    echo ""
    echo -e "${BOLD}Examples:${NC}"
    echo -e "  ${YELLOW}./pm run${NC}        → Shows menu, press 1 for USER iOS"
    echo -e "  ${YELLOW}./pm build${NC}      → Shows menu, press 13 for build all"
    echo -e "  ${YELLOW}./pm build-all${NC}  → Directly builds everything"
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════════
main() {
    # Make sure we're in the project directory
    cd "$(dirname "$0")" || exit 1
    
    case "${1:-}" in
        run|r)
            run_menu
            ;;
        build|b)
            build_menu
            ;;
        build-all|ba|all)
            build_all
            ;;
        ios)
            build_all_ios
            ;;
        android)
            build_all_android
            ;;
        help|h|-h|--help)
            show_help
            ;;
        "")
            # No argument - show main menu
            clear
            echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
            echo -e "${BOLD}${GREEN}  ⚡ PLAYMAKER QUICK COMMANDS${NC}"
            echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
            echo ""
            echo -e "  ${GREEN}1)${NC} 🚀 Run App       ${YELLOW}Development/Testing${NC}"
            echo -e "  ${GREEN}2)${NC} 📦 Build App     ${YELLOW}Production Release${NC}"
            echo -e "  ${GREEN}3)${NC} ⚡ Build All     ${YELLOW}All apps, all platforms${NC}"
            echo ""
            echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
            echo -e "  ${RED}0)${NC} Exit"
            echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
            echo ""
            echo -ne "${BOLD}Select option [0-3]: ${NC}"
            read -r choice
            
            case $choice in
                1)
                    run_menu
                    ;;
                2)
                    build_menu
                    ;;
                3)
                    build_all
                    ;;
                0|"")
                    echo -e "\n${YELLOW}Goodbye!${NC}"
                    ;;
                *)
                    echo -e "\n${RED}Invalid option.${NC}"
                    ;;
            esac
            ;;
        *)
            echo -e "${RED}Unknown command: $1${NC}"
            echo -e "Run ${GREEN}./pm help${NC} for usage"
            ;;
    esac
}

# Run main
main "$@"
