# ════════════════════════════════════════════════════════════════════════════════
# PLAYMAKER .gitignore
# ════════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# Build Outputs (IMPORTANT - excludes all build folders)
# ─────────────────────────────────────────────────────────────────────────────────
**/build/
/build/
promoapp/build/
*.aab
*.apk
*.ipa
*.app

# ─────────────────────────────────────────────────────────────────────────────────
# Screenshots & Images at root level (development artifacts)
# ─────────────────────────────────────────────────────────────────────────────────
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.mov
/*.mp4
/screen_*.png
/emulator_*.png
/adv*.png
/albaseet*.png
/book*.png
/bepro*.png
/check*.png
/menu*.png
/phase*.png
/rec_*.png
/recordings*.png
/running*.png
/tap*.png

# ─────────────────────────────────────────────────────────────────────────────────
# Flutter/Dart/Pub related
# ─────────────────────────────────────────────────────────────────────────────────
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
pubspec.lock

# ─────────────────────────────────────────────────────────────────────────────────
