# ─────────────────────────────────────────────────────────────────────────────────
**/android/.gradle/
**/android/app/debug
**/android/app/profile
**/android/app/release
**/android/local.properties
*.keystore
!android/app/upload-keystore.jks

# ─────────────────────────────────────────────────────────────────────────────────
# macOS specific
# ─────────────────────────────────────────────────────────────────────────────────
**/macos/Flutter/ephemeral/
**/macos/Pods/

# ─────────────────────────────────────────────────────────────────────────────────
# Credentials & Secrets (NEVER COMMIT THESE!)
# ─────────────────────────────────────────────────────────────────────────────────
.env
*.env
*credentials*.txt
supabase*.txt
android/playmaker-play-console-service-account.json
android/*.json
!android/google-services.json
fastlane/private_keys/
*.p8
AuthKey_*.p8

# ─────────────────────────────────────────────────────────────────────────────────
# Fastlane
# ─────────────────────────────────────────────────────────────────────────────────
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/
fastlane/README.md

