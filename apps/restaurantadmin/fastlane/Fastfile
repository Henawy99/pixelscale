# ============================================
# Restaurant Admin - iOS Fastlane Configuration
# ============================================
# Automated build and upload to TestFlight
# ============================================

default_platform(:ios)

platform :ios do

  # ─────────────────────────────────────────
  # Setup API Key (runs before every lane)
  # ─────────────────────────────────────────
  before_all do
    UI.header("🍔 Restaurant Admin - iOS Automation")

    # App Store Connect API Key Configuration
    # Replace these values with your own:
    #   - key_id:       Your Key ID from App Store Connect → Integrations
    #   - issuer_id:    Your Issuer ID from the same page
    #   - key_filepath: Path to your .p8 key file
    @api_key = app_store_connect_api_key(
      key_id: "6RM87HWDZY",
      issuer_id: "dc9a069b-00fc-45f8-be31-84e435ea4d07",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_6RM87HWDZY.p8"),
      duration: 1200,
      in_house: false
    )

    UI.success("✅ API Key configured successfully")
  end

  # ─────────────────────────────────────────
  # Lane: Build & Upload to TestFlight
  # ─────────────────────────────────────────
  desc "Build iOS app and upload to TestFlight"
  lane :upload_app do
    UI.header("📦 Building & Uploading to TestFlight")

    # Extract version info from pubspec.yaml
    pubspec = File.read("../pubspec.yaml")
    version_match = pubspec.match(/version:\s*(\d+\.\d+\.\d+)\+(\d+)/)

    if version_match
      version_name = version_match[1]
      version_code = version_match[2]
      UI.message("📊 Version: #{version_name} (Build #{version_code})")
    else
      UI.error("❌ Could not read version from pubspec.yaml")
      UI.error("   Make sure pubspec.yaml has: version: X.Y.Z+N")
      next
    end

    # Build the IPA using gym (aka build_app)
    UI.message("🔨 Building IPA...")
    begin
      gym(
        workspace: File.expand_path("../ios/Runner.xcworkspace", File.dirname(__FILE__)),
        scheme: "Runner",
        export_method: "app-store",
        output_directory: File.expand_path("../build/ios/ipa", File.dirname(__FILE__)),
        output_name: "RestaurantAdmin.ipa",
        clean: true,
        export_options: {
          signingStyle: "automatic",
          uploadBitcode: false,
          uploadSymbols: true,
          compileBitcode: false
        }
      )
      UI.success("✅ IPA built successfully!")
    rescue => e
      UI.error("❌ Build failed!")
      UI.error("   Error: #{e.message}")
      UI.error("")
      UI.error("   Troubleshooting:")
      UI.error("   1. Make sure you have valid signing certificates")
      UI.error("   2. Run: cd ios && pod install --repo-update && cd ..")
      UI.error("   3. Open Xcode and check Signing & Capabilities")
      UI.error("   4. Make sure your Team ID is correct in fastlane/Appfile")
      raise e
    end

    # Build the IPA using gym (aka build_app)
    # Upload to TestFlight
    UI.message("🚀 Uploading to TestFlight...")
    begin
      upload_to_testflight(
        api_key: @api_key,
        skip_waiting_for_build_processing: true,
        skip_submission: false,
        distribute_external: false,
        changelog: "Version #{version_name} (Build #{version_code})",
        ipa: File.expand_path("../build/ios/ipa/RestaurantAdmin.ipa", File.dirname(__FILE__))
      )
      UI.success("✅ Successfully uploaded to TestFlight!")
    rescue => e
      UI.error("❌ TestFlight upload failed!")
      UI.error("   Error: #{e.message}")
      UI.error("")
      UI.error("   Troubleshooting:")
      UI.error("   1. Check your API Key ID and Issuer ID in fastlane/Fastfile")
      UI.error("   2. Make sure AuthKey .p8 file exists at ~/.appstoreconnect/private_keys/")
      UI.error("   3. Verify your app is registered in App Store Connect")
      UI.error("   4. Check that the bundle ID matches: com.mycoolrestaurant.adminapp")
      raise e
    end

    UI.header("🎉 SUCCESS!")
    UI.success("Version #{version_name} (Build #{version_code}) uploaded to TestFlight!")
    UI.message("Check TestFlight in App Store Connect in 5-15 minutes.")
  end

  # ─────────────────────────────────────────
  # Lane: Build Only (no upload)
  # ─────────────────────────────────────────
  desc "Build iOS app without uploading"
  lane :build_only do
    UI.header("📦 Building iOS (No Upload)")

    gym(
      workspace: File.expand_path("../ios/Runner.xcworkspace", File.dirname(__FILE__)),
      scheme: "Runner",
      export_method: "app-store",
      output_directory: File.expand_path("../build/ios/ipa", File.dirname(__FILE__)),
      output_name: "RestaurantAdmin.ipa",
      clean: true,
      export_options: {
        signingStyle: "automatic",
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false
      }
    )

    UI.success("✅ IPA built at: build/ios/ipa/RestaurantAdmin.ipa")
  end

  # ─────────────────────────────────────────
  # Error handling
  # ─────────────────────────────────────────
  error do |lane, exception|
    UI.error("❌ Fastlane encountered an error in lane '#{lane}'")
    UI.error("   #{exception.message}")
  end

end
