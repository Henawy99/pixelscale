#!/bin/bash

# ═══════════════════════════════════════════════════════════════════════════════
# PLAYMAKER INTERACTIVE COMMAND MENU
# ═══════════════════════════════════════════════════════════════════════════════
# Usage:
#   ./pm run       - Interactive menu to run an app
#   ./pm build     - Interactive menu to build an app
#   ./pm build-all - Build all apps (iOS + Android)
#   ./pm help      - Show help
# ═══════════════════════════════════════════════════════════════════════════════

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
MAGENTA='\033[0;35m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# ═══════════════════════════════════════════════════════════════════════════════
# RUN MENU
# ═══════════════════════════════════════════════════════════════════════════════
run_menu() {
    clear
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}${GREEN}  🚀 PLAYMAKER - RUN APP${NC}"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -e "${BOLD}📱 iOS (Device/Simulator)${NC}"
    echo -e "  ${GREEN}1)${NC} USER App          ${YELLOW}scripts/run_user_app.sh${NC}"
    echo -e "  ${GREEN}2)${NC} MANAGEMENT App    ${YELLOW}scripts/run_management_app.sh${NC}"
    echo -e "  ${GREEN}3)${NC} PROMO App         ${YELLOW}scripts/run_promo_app.sh${NC}"
    echo ""
    echo -e "${BOLD}🤖 Android (Device/Emulator)${NC}"
    echo -e "  ${GREEN}4)${NC} USER App          ${YELLOW}scripts/run_user_app_android.sh${NC}"
    echo -e "  ${GREEN}5)${NC} MANAGEMENT App    ${YELLOW}scripts/run_management_app_android.sh${NC}"
    echo ""
    echo -e "${BOLD}🖥️  Desktop (macOS)${NC}"
    echo -e "  ${GREEN}6)${NC} MANAGEMENT Desktop ${YELLOW}scripts/run_management_app_desktop.sh${NC} ${MAGENTA}⭐ Best for uploads${NC}"
    echo ""
    echo -e "${BOLD}🌐 Web (Chrome)${NC}"
    echo -e "  ${GREEN}7)${NC} ADMIN Web          ${YELLOW}scripts/run_admin_app_web.sh${NC}"
    echo ""
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo -e "  ${RED}0)${NC} Cancel"
    echo -e "${CYAN}═══════════════════════════════════════════════════════════════${NC}"
    echo ""
    echo -ne "${BOLD}Select option [0-8]: ${NC}"
    read -r choice
    
    case $choice in
        1)
            echo -e "\n${GREEN}▶ Running USER App on iOS...${NC}\n"
            scripts/run_user_app.sh
            ;;
        2)
            echo -e "\n${GREEN}▶ Running MANAGEMENT App on iOS...${NC}\n"
            scripts/run_management_app.sh
            ;;
        3)
            echo -e "\n${GREEN}▶ Running PROMO App on iOS...${NC}\n"
            scripts/run_promo_app.sh
            ;;
        4)
            echo -e "\n${GREEN}▶ Running USER App on Android...${NC}\n"
            scripts/run_user_app_android.sh
            ;;
        5)
            echo -e "\n${GREEN}▶ Running MANAGEMENT App on Android...${NC}\n"
            scripts/run_management_app_android.sh
            ;;
        6)
            echo -e "\n${GREEN}▶ Running MANAGEMENT App as Desktop...${NC}\n"
            scripts/run_management_app_desktop.sh
            ;;
        7)
            echo -e "\n${GREEN}▶ Running ADMIN App on Web...${NC}\n"
            scripts/run_admin_app_web.sh
            ;;
        0|"")
            echo -e "\n${YELLOW}Cancelled.${NC}"
            ;;
        *)
            echo -e "\n${RED}Invalid option. Please try again.${NC}"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════════════════
# BUILD MENU
