# Animight iOS Fastlane Configuration
# =====================================
# Automated build and upload to TestFlight
#
# Usage:
#   bundle exec fastlane ios upload        # Build + Upload to TestFlight
#   bundle exec fastlane ios upload_only   # Upload existing IPA (skip build)

default_platform(:ios)

# ═══════════════════════════════════════════════════════════════════════════════
# API KEY CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
API_KEY_ID        = "2GTNSM4DX2"
API_KEY_ISSUER_ID = "dc9a069b-00fc-45f8-be31-84e435ea4d07"
API_KEY_PATH      = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_2GTNSM4DX2.p8")

# ═══════════════════════════════════════════════════════════════════════════════
# iOS PLATFORM
# ═══════════════════════════════════════════════════════════════════════════════

platform :ios do

  # ─────────────────────────────────────────────────────────────────────────────
  # Setup API Key for all lanes
  # ─────────────────────────────────────────────────────────────────────────────

  before_all do
    app_store_connect_api_key(
      key_id: API_KEY_ID,
      issuer_id: API_KEY_ISSUER_ID,
      key_filepath: API_KEY_PATH,
      in_house: false
    )
  end

  # ═══════════════════════════════════════════════════════════════════════════════
  # MAIN LANE — Build Flutter + Archive + Upload
  # ═══════════════════════════════════════════════════════════════════════════════

  desc "Build Flutter app and upload to TestFlight"
  lane :upload do
    UI.header "Building & Uploading Animight to TestFlight"

    project_root = File.expand_path("..", Dir.pwd)

    # Flutter build — run outside Bundler context so CocoaPods/pod is found correctly
    UI.message "Running flutter build ios..."
    Dir.chdir(project_root) do
      Bundler.with_unbundled_env do
        sh("flutter build ios --release --no-codesign")
      end
    end

    workspace_path = File.join(project_root, "ios/Runner.xcworkspace")

    gym(
      workspace: workspace_path,
      scheme: "Runner",
      export_method: "app-store",
      output_directory: File.join(project_root, "build/ios"),
      output_name: "Animight.ipa",
      clean: false,
      include_bitcode: false,
      xcargs: "DEVELOPMENT_TEAM=G67XQ5S4QU",
      export_options: {
        signingStyle: "automatic",
        teamID: "G67XQ5S4QU",
        uploadBitcode: false,
        uploadSymbols: true,
        compileBitcode: false
      }
    )

    ipa_path = lane_context[SharedValues::IPA_OUTPUT_PATH]
    UI.message "IPA created: #{ipa_path}"
    UI.message "Uploading to TestFlight..."

    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )

    UI.success "Animight uploaded to TestFlight!"
    UI.message "Check App Store Connect in 5-10 minutes for processing."
  end

  # ═══════════════════════════════════════════════════════════════════════════════
  # UPLOAD ONLY — Skip Flutter build, use existing IPA
  # ═══════════════════════════════════════════════════════════════════════════════

  desc "Upload existing IPA to TestFlight (skip build)"
  lane :upload_only do
    project_root = File.expand_path("..", Dir.pwd)
    ipa_path     = File.join(project_root, "build/ios/Animight.ipa")

    UI.header "Uploading Animight IPA to TestFlight"
    UI.message "IPA path: #{ipa_path}"

    unless File.exist?(ipa_path)
      UI.user_error!("IPA not found at: #{ipa_path}\nPlease build first with: bundle exec fastlane ios upload")
    end

    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
      skip_submission: true,
      distribute_external: false,
      notify_external_testers: false
    )

    UI.success "Animight uploaded to TestFlight!"
  end

  # Short alias
  lane :tf do
    upload
  end

  # ═══════════════════════════════════════════════════════════════════════════════
  # ERROR HANDLING
  # ═══════════════════════════════════════════════════════════════════════════════

  error do |lane, exception|
    UI.error "Lane #{lane} failed!"
    UI.error exception.message

    if exception.message.include?("API") || exception.message.include?("key")
      UI.important ""
      UI.important "Check your API key configuration in fastlane/Fastfile:"
      UI.important "  Key ID:    #{API_KEY_ID}"
      UI.important "  Key file:  #{API_KEY_PATH}"
      UI.important "  Exists:    #{File.exist?(API_KEY_PATH)}"
      UI.important ""
      UI.important "Key file path: #{API_KEY_PATH}"
    end

    if exception.message.include?("provisioning") || exception.message.include?("signing")
      UI.important ""
      UI.important "Signing issue — check Xcode:"
      UI.important "  1. Open ios/Runner.xcworkspace"
      UI.important "  2. Select Runner target → Signing & Capabilities"
      UI.important "  3. Enable 'Automatically manage signing'"
    end
  end

end
